{
  "name": "neurosync-desktop",
  "version": "1.0.0",
  "description": "NeuroSync Desktop Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.neurosync.desktop",
    "productName": "NeuroSync",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../desktop-agent",
        "to": "desktop-agent",
        "filter": ["**/*"]
      }
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  }
}